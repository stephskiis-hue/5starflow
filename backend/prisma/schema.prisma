generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Stores the connected Jobber account's OAuth tokens.
// Multi-tenant: one row per Jobber org, linked to the portal User who connected it.
model JobberAccount {
  id           String   @id @default(cuid())
  accountId    String   @unique  // Jobber account/org ID from token response
  userId       String?           // portal User.id — links this Jobber org to a portal user
  accessToken  String
  refreshToken String
  expiresAt    DateTime           // UTC: when the access token expires
  webhookId    String?            // Jobber webhook endpoint ID once registered
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaignClients CampaignClient[]
  campaigns       Campaign[]

  @@index([userId])
}

// Audit log for every token refresh attempt (success or failure).
// Powers the /api/token-logs endpoint and dashboard health monitor.
model TokenRefreshLog {
  id        String   @id @default(cuid())
  accountId String                   // Jobber account ID (for reference)
  success   Boolean                  // true = refreshed OK, false = failed
  message   String                   // e.g. "Token refreshed" or error text
  trigger   String   @default("scheduler") // "scheduler" | "on-demand"
  createdAt DateTime @default(now())
}

// Tracks which clients have already received a review request.
// Secondary deduplication layer in case Jobber tag API is temporarily down.
model ReviewSent {
  id        String   @id @default(cuid())
  clientId  String   @unique  // Jobber EncodedId of the client
  invoiceId String             // Invoice that triggered the send
  accountId String?            // Jobber account ID — for per-account visibility
  sentAt    DateTime @default(now())
}

// Portal users — email must match the license email used to purchase.
// Create the first user via POST /auth/setup-user with the SETUP_TOKEN.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  googleId     String?  @unique
  role         String   @default("client")  // "admin" | "client"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  campaignClients CampaignClient[]
  campaigns       Campaign[]
}

// Delay queue: invoices queued for review request, sent after REVIEW_DELAY_MINUTES.
// invoiceId is unique so webhook retries and poller duplicates are silently ignored.
model PendingReview {
  id          String   @id @default(cuid())
  invoiceId   String   @unique  // Jobber invoice ID — idempotency key
  clientId    String
  clientName  String
  firstName   String
  phone       String?           // null if client has no primary phone
  smsAllowed  Boolean  @default(false)
  email       String?           // null if client has no primary email
  scheduledAt DateTime          // when to send = enqueued time + REVIEW_DELAY_MINUTES
  processed            Boolean   @default(false)
  cancelled            Boolean   @default(false)
  channel              String?             // "sms" | "email" — which channel was used for initial send
  followUpScheduledAt  DateTime?           // set after initial send if client has email (now + 24h)
  followUpSent         Boolean   @default(false)
  userId               String?             // portal user who owns this queued review
  createdAt            DateTime  @default(now())
}

// Daily weather check log — one row per morning check run.
model WeatherCheck {
  id              String   @id @default(cuid())
  date            String   // YYYY-MM-DD
  rainExpected    Boolean
  maxPrecipProb   Float    // 0.0–1.0 (highest pop in business hours)
  forecastSummary String   // e.g. "Rain likely 9am–2pm (72%)"
  userId          String?  // portal user who owns this check
  checkedAt       DateTime @default(now())

  @@index([userId])
}

// Audit log for every rain reschedule batch notification sent.
model RainReschedule {
  id           String   @id @default(cuid())
  originalDay  String   // "monday"
  originalDate String   // YYYY-MM-DD
  newDate      String   // YYYY-MM-DD
  clientCount  Int
  smsCount     Int      @default(0)
  emailCount   Int      @default(0)
  message      String   // actual message text that was sent
  userId       String?  // portal user who owns this reschedule
  notifiedAt   DateTime @default(now())

  @@index([userId])
}

// Per-client, per-channel log for every rain reschedule message sent.
model RainMessage {
  id            String   @id @default(cuid())
  rescheduleId  String   // FK to RainReschedule.id
  visitId       String
  clientId      String
  clientName    String
  channel       String   // "sms" | "email"
  status        String   @default("sent")  // "sent" | "failed" | "delivered" | "undelivered"
  messageSid    String?  // Twilio message SID (for delivery callbacks)
  error         String?  // error message if status is "failed"
  sentAt        DateTime @default(now())
  userId        String?

  @@index([rescheduleId])
  @@index([userId])
}

// Per-user settings row for the weather/rain feature.
model WeatherSettings {
  id                     String  @id @default(cuid())
  userId                 String? @unique  // one row per user
  city                   String  @default("Winnipeg")
  rainThreshold          Float   @default(0.4)   // 40% pop = rain warning
  businessStartHour      Int     @default(7)
  businessEndHour        Int     @default(18)
  preferredRescheduleDay String  @default("")    // saved dropdown value (YYYY-MM-DD)
  checkEnabled           Boolean @default(true)
  rainSmsTemplate        String  @default("")    // user-saved SMS template; supports {firstName} and {newDate}
}

// SEO: one row per weekly audit run.
model SeoAudit {
  id               String   @id @default(cuid())
  siteUrl          String
  status           String   @default("running")  // running | complete | failed
  performanceScore Int?
  lcp              Float?   // Largest Contentful Paint (s)
  cls              Float?   // Cumulative Layout Shift
  fid              Float?   // First Input Delay (ms)
  keywordsJson     String?  // JSON array: [{ keyword, clicks, impressions, position }]
  competitorJson   String?  // JSON array: [{ url, title, h1s, wordCount, schema }]
  insightJson      String?  // JSON array: generated insights
  userId           String?  // portal user who owns this audit
  runAt            DateTime @default(now())

  @@index([userId])
}

// SEO: one proposal per audit — operator approves or declines.
model SeoProposal {
  id          String    @id @default(cuid())
  auditId     String
  status      String    @default("pending")  // pending | approved | declined
  title       String
  summaryJson String    // JSON array: [{ insight, impact, fix, fileTarget }]
  userId      String?   // portal user who owns this proposal
  respondedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// SEO: individual file changes attached to a proposal.
model SeoChange {
  id          String    @id @default(cuid())
  proposalId  String
  filePath    String
  oldContent  String
  newContent  String
  description String
  status      String    @default("pending")  // pending | applied | failed
  userId      String?   // portal user who owns this change
  appliedAt   DateTime?
  errorMsg    String?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// Website Audit: FTP server credentials — one config per user.
model FtpConfig {
  id                String   @id @default(cuid())
  userId            String?  // portal user who owns this config
  host              String
  user              String
  encryptedPassword String
  rootPath          String   @default("/public_html")
  port              Int      @default(21)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

// Website Audit: path patterns to exclude from FTP scans (e.g. "cgi-bin", "wp-admin").
model AuditIgnore {
  id        String   @id @default(cuid())
  pattern   String
  userId    String?  // portal user who owns this ignore rule
  createdAt DateTime @default(now())

  @@unique([userId, pattern])
  @@index([userId])
}

// Website Audit: one row per HTML file discovered on the FTP server.
// Status flow: discovered → pulled → auditing → audited → edited → pushed → done
model AuditPage {
  id              String    @id @default(cuid())
  path            String    // full remote path e.g. /public_html/about.html
  filename        String
  status          String    @default("discovered")
  localContent    String?             // raw HTML pulled from server
  userId          String?             // portal user who owns this page
  lastPulled      DateTime?
  lastPushed      DateTime?
  auditScore      Int?                // composite 0-100 (SEO + perf)
  seoScore        Int?
  perfScore       Int?
  auditIssuesJson String?             // JSON: [{ type, severity, message, fix }]
  pageUrl         String?             // full public URL for PageSpeed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, path])
  @@index([userId])
}

// SEO: per-user settings row — site URL, competitors, deploy config, Google tokens.
model SeoSettings {
  id                 String   @id @default(cuid())
  userId             String?  @unique  // one row per user
  siteUrl            String   @default("")
  competitorUrls     String   @default("[]")   // JSON array of competitor URLs
  deployType         String   @default("none") // "git" | "ftp" | "none"
  deployHost         String?
  deployPort         Int?
  deployUser         String?
  deployPass         String?
  deployPath         String?
  deployBranch       String   @default("main")
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  siteProperty       String?  // Search Console property e.g. "sc-domain:nobsyardwork.com"
  ga4PropertyId      String?  // GA4 property ID e.g. "properties/123456789"
  auditEnabled       Boolean  @default(true)
  deepAnalysis       Boolean  @default(false) // true = Sonnet (~4¢), false = Haiku (~0.7¢)
  updatedAt          DateTime @updatedAt
  createdAt          DateTime @default(now())
}

// Per-user Twilio SMS credentials.
model TwilioCredential {
  id          String   @id @default(cuid())
  userId      String   @unique  // one row per user
  accountSid  String
  authToken   String
  fromNumber  String
  notifyPhone String?           // admin's personal mobile — gets SMS when client replies Y/N
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Loyalty & Referral Engine — tracks client points, referral slugs, and multiplier flags.
// One row per (userId, jobberClientId) pair. optedOut=true excludes from leaderboard.
model LoyaltyClient {
  id                   String   @id @default(cuid())
  userId               String                          // portal User.id who owns this record
  jobberClientId       String                          // Jobber encoded client ID
  displayName          String                          // "First L." privacy format
  totalPoints          Int      @default(0)
  referralSlug         String   @unique                // short unique token, e.g. "jd-a8f3"
  hasPendingMultiplier Boolean  @default(false)        // next invoice earns 20 pts instead of 10
  optedOut             Boolean  @default(false)        // client requested removal from game
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, jobberClientId])
  @@index([userId])
}

// PageSpeed score history — one row per Free Site Score run.
model PageSpeedHistory {
  id           String   @id @default(cuid())
  userId       String?
  siteUrl      String
  mobileScore  Int?
  desktopScore Int?
  mobileSeo    Int?
  lcp          Float?
  cls          Float?
  fid          Float?
  issuesJson   String?  // JSON: [{ id, category, title, score, savings }]
  runAt        DateTime @default(now())

  @@index([userId])
}

// Per-user message customization for review request emails and SMS.
model MessageSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  businessName    String   @default("My Business")
  tagline         String   @default("")
  logoUrl         String   @default("")
  reviewLink      String   @default("")
  buttonColor     String   @default("#1b5e20")
  emailSubject    String   @default("Could you do us a small favor?")
  emailBody       String   @default("We hope you're loving the results! We'd love to hear what you think.")
  emailCustomHtml String   @default("")
  smsBody         String   @default("")
  updatedAt       DateTime @updatedAt
}

// Per-user Gmail credentials for outbound email (Google OAuth2).
model GmailCredential {
  id           String    @id @default(cuid())
  userId       String    @unique  // one row per user
  gmailUser    String              // connected Gmail address
  fromName     String    @default("")
  accessToken  String    @default("")
  refreshToken String?
  tokenExpiry  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model MessageTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, type])
}

// Tracks when each integration was last successfully verified (test passed or OAuth connected).
// Green checkmark only shows when a record exists here.
model ConnectionVerification {
  id         String   @id @default(cuid())
  userId     String
  service    String   // 'jobber' | 'gmail' | 'twilio' | 'openweather' | 'pagespeed'
  verifiedAt DateTime @default(now())

  @@unique([userId, service])
}

// ---------------------------------------------------------------------------
// SMS Marketing System
// ---------------------------------------------------------------------------

// Reusable SMS message templates. Supports {firstName} placeholder.
model MarketingTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Named audience list — a saved set of contacts imported from Jobber.
model AudienceList {
  id        String            @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  contacts  AudienceContact[]

  @@index([userId])
}

// Join table: one row per contact in an audience list (snapshot at import time).
model AudienceContact {
  id             String       @id @default(cuid())
  audienceListId String
  audienceList   AudienceList @relation(fields: [audienceListId], references: [id], onDelete: Cascade)
  jobberClientId String
  clientName     String
  firstName      String
  phone          String?
  smsAllowed     Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([audienceListId, jobberClientId])
  @@index([audienceListId])
}

// One campaign = one send job (template + audience). messageBody is frozen snapshot.
model MarketingCampaign {
  id              String             @id @default(cuid())
  userId          String
  name            String
  templateId      String
  audienceListId  String
  messageBody     String
  status          String             @default("pending")
  totalRecipients Int                @default(0)
  sentCount       Int                @default(0)
  failedCount     Int                @default(0)
  skippedCount    Int                @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime           @default(now())
  messages        MarketingMessage[]

  @@index([userId])
}

// Per-recipient delivery log within a campaign.
model MarketingMessage {
  id              String            @id @default(cuid())
  campaignId      String
  campaign        MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  jobberClientId  String
  clientName      String
  firstName       String
  phone           String?
  status          String            @default("pending")
  messageSid      String?
  error           String?
  sentAt          DateTime?
  replyBody       String?           // client's reply text (set when inbound SMS is matched)
  replyReceivedAt DateTime?         // when the reply arrived
  createdAt       DateTime          @default(now())

  @@index([campaignId])
  @@index([messageSid])
}

// ---------------------------------------------------------------------------
// Cached Jobber Clients — populated by background sync service (jobberClientSync.js)
// Replaces live-on-demand Jobber API calls in the audience builder.
// ---------------------------------------------------------------------------
model CachedJobberClient {
  id             String    @id @default(cuid())
  userId         String                          // portal User.id (matches JobberAccount.userId)
  jobberClientId String                          // Jobber's own client GID
  name           String
  firstName      String
  phone          String?
  smsAllowed     Boolean   @default(false)
  tags           String    @default("[]")        // JSON array stored as string
  optedOut       Boolean   @default(false)       // true if client texted STOP
  optedOutAt     DateTime?                       // when they opted out
  syncedAt       DateTime  @default(now())

  @@unique([userId, jobberClientId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Inbound SMS — every message received on the Twilio marketing number.
// Linked to CachedJobberClient and the most recent campaign that texted them.
// ---------------------------------------------------------------------------
model InboundSMS {
  id             String   @id @default(cuid())
  userId         String                          // portal user whose Twilio number received this
  from           String                          // E.164 sender phone
  body           String                          // raw message text
  messageSid     String   @unique               // Twilio MessageSid (dedup guard)
  isResponse     Boolean  @default(false)        // true if body is Y/N/YES/NO
  response       String?                         // normalized: "yes" | "no" | null
  clientName     String?                         // matched from CachedJobberClient (or null)
  jobberClientId String?                         // matched client ID (or null)
  campaignId     String?                         // most recent campaign that texted this number
  notified       Boolean  @default(false)        // has admin been notified via SMS?
  read           Boolean  @default(false)        // has admin viewed in the Inbox tab?
  receivedAt     DateTime @default(now())

  @@index([userId])
  @@index([from])
}

// ---------------------------------------------------------------------------
// Campaign Management System (v2)
// Source of truth: JobberAccount + Jobber GraphQL
// Campaign state: clients/campaigns/campaign_members (stored locally)
// ---------------------------------------------------------------------------

model CampaignClient {
  id               String   @id @default(cuid())
  userId           String
  jobberAccountId  String
  jobberClientId   String
  fullName         String
  primaryPhone     String?
  primaryEmail     String?
  smsAllowedFlag   Boolean?
  smsConsentStatus String?
  emailConsentStatus String?
  isSmsEligible    Boolean  @default(false)
  isEmailEligible  Boolean  @default(false)
  tags             Json     @db.JsonB
  optedOut         Boolean  @default(false)
  optedOutAt       DateTime?
  syncedAt         DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobberAccount JobberAccount @relation(fields: [jobberAccountId], references: [id], onDelete: Cascade)
  members       CampaignMember[]

  @@unique([jobberAccountId, jobberClientId])
  @@index([userId])
  @@index([jobberAccountId])
  @@map("clients")
}

model Campaign {
  id              String   @id @default(cuid())
  userId          String
  jobberAccountId String
  name            String
  type            String   // "SMS" | "EMAIL" (enforced in DB via CHECK constraint)
  status          String   @default("draft") // draft|active|paused|complete|failed
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobberAccount JobberAccount @relation(fields: [jobberAccountId], references: [id], onDelete: Cascade)
  members       CampaignMember[]

  @@index([userId])
  @@index([jobberAccountId])
  @@unique([jobberAccountId, name, type])
  @@map("campaigns")
}

model CampaignMember {
  campaignId      String
  clientId        String
  status          String   @default("pending") // pending|sent|failed|skipped
  channelOverride String?  // null|"SMS"|"EMAIL"
  isRemoved       Boolean  @default(false)
  sentAt          DateTime?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  client   CampaignClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([campaignId, clientId])
  @@index([campaignId, status])
  @@map("campaign_members")
}
