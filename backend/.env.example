# Jobber OAuth App Credentials
# Get these from: developer.getjobber.com → your app → App Settings
JOBBER_CLIENT_ID=your_jobber_app_client_id
JOBBER_CLIENT_SECRET=your_jobber_app_client_secret

# Webhook signing secret
# Get this from: developer.getjobber.com → your app → Webhooks (after creating a webhook)
JOBBER_WEBHOOK_SECRET=your_jobber_webhook_signing_secret

# OAuth redirect URI — must be your ngrok public URL (localhost not supported by Jobber)
# Run: ngrok http 3001 → copy the https URL → use it here AND in Jobber app settings
JOBBER_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/auth/callback

# Jobber API endpoints (do not change unless Jobber updates them)
JOBBER_AUTH_URL=https://api.getjobber.com/api/oauth/authorize
JOBBER_TOKEN_URL=https://api.getjobber.com/api/oauth/token
JOBBER_GRAPHQL_URL=https://api.getjobber.com/api/graphql

# Express server port
PORT=3001

# Your ngrok public URL — used for CORS and for the OAuth redirect after login
# Must match your ngrok URL exactly (no trailing slash)
FRONTEND_ORIGIN=https://your-ngrok-url.ngrok-free.app

# The Google (or other platform) review link sent to clients
REVIEW_LINK=https://g.page/r/CSu2cqDYFOxDEAE/review

# ── Twilio SMS ──────────────────────────────────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+14314509814

# ── Gmail SMTP ──────────────────────────────────────────────────────────────
# Use a Google App Password (NOT your regular password).
# Enable 2FA on your Google account → myaccount.google.com/apppasswords → generate one.
GMAIL_USER=nobsyardwork@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=No-Bs Yardwork

# ── Queue timing & polling ───────────────────────────────────────────────────
REVIEW_DELAY_MINUTES=60      # minutes to wait after invoice paid before sending (default: 60)
POLL_INTERVAL_MINUTES=30     # how often to poll Jobber for missed paid invoices (default: 30). Shorter intervals increase API usage and throttling risk.
POLL_WINDOW_MINUTES=35       # look-back window for poller (must be >= POLL_INTERVAL_MINUTES to ensure overlap; default: 35)
MAX_PAGES_PER_POLL=5         # safety cap on how many pages of invoices to fetch per poll run (lower values reduce throttling risk)
THROTTLE_COOLDOWN_SECONDS=60 # how long to back off after a Jobber \"Throttled\"/429 response before next scheduled run handles more polling

# Set to true to log SMS/email instead of actually sending (safe for testing)
DRY_RUN=false
